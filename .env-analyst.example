# AI Job Hunter — Environment Variables Template
# Copy this file to .env-analyst and fill in your actual values.
# NEVER commit the real .env-analyst to GitHub.

# === Telegram ===
export TELEGRAM_BOT_TOKEN='your_telegram_bot_token_here'
export TELEGRAM_CHAT_ID='your_telegram_chat_id_here'
export TELEGRAM_BOT_USERNAME='@your_bot_username'
export TELEGRAM_API_ID='your_api_id'
export TELEGRAM_API_HASH='your_api_hash'

# === Google Gemini AI (Free Tier — 1500 req/day) ===
# Get key at: https://aistudio.google.com/apikey
export GEMINI_API_KEY='your_gemini_api_key_here'

# === Cloud Database (NeonDB / Supabase PostgreSQL) ===
# Get connection string from: https://neon.tech
export DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# === Job Search Config ===
export JOB_WINDOW=2d
export LOCATION_PRIMARY='India'
export EXPERIENCE_LEVEL='0-2 years'
export JOB_TYPE='Job,Internship'
export MAX_NOTIFY_JOBS=40

# === Scheduling ===
export AUTOPILOT_INTERVAL_SECONDS=7200    # Every 2 hours
export ENABLE_BACKGROUND_RUNNER=1

# === Filtering ===
export ALLOW_FALLBACK_JOBS=0              # Only real jobs, no synthetic data
export ALLOW_MOCK_FALLBACK=0
export STRICT_ROLE_MATCH=0
