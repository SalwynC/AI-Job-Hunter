# =============================================================================
# AI Job Hunter — .gitignore
# =============================================================================

# --- Secrets & Environment ---
.env
.env.*
.env-analyst
*.env

# --- Neon CLI context ---
.neon

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
*.so
.Python
venv/
env/
.venv/

# --- Generated data (all runtime output) ---
data/
logs/
*.log

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Node (if any tooling added later) ---
node_modules/

# --- Debug/temp images ---
*.png
*.jpg
*.jpeg
*.webp

# --- Test cache ---
.pytest_cache/
.coverage
htmlcov/
